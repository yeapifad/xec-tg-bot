# ── Required ──────────────────────────────────────────────────
# Your bot token from @BotFather
BOT_TOKEN=123456:ABCdef...

# Comma-separated Telegram user IDs of admins
# Get your ID from @userinfobot
ADMIN_IDS=123456789,987654321

# Your engage group/supergroup chat ID (negative number)
# Add @getidsbot to your group to find it
ENGAGE_GROUP_ID=-1001234567890

# ── Render / Webhook ──────────────────────────────────────────
# Your Render app URL (no trailing slash)
WEBHOOK_URL=https://xec-bot.onrender.com

# Render sets PORT automatically — leave as-is
PORT=8000

# Optional: random secret string to verify webhook requests
WEBHOOK_SECRET=change_this_to_something_random

# ── Extension report API ──────────────────────────────────────
# Secret key the extension sends as X-Api-Key header
REPORT_API_KEY=change_this_to_something_random_too

# ── Database ──────────────────────────────────────────────────
# Path to SQLite file — Render disk or default local
DB_PATH=xec.db
